# pstack — gitignore

# Private conversation log (use publish-docs to generate the public version)
CONVERSATIONS.md

# Per-project challenge logs (user's strategic reflections — opt-in commit)
pstack-workspace/*/CHALLENGES.md

# Per-skill user feedback logs (personal; never pushed to public repo)
feedback/vision-log.yaml
feedback/prd-log.yaml
feedback/design-brief-log.yaml

# Private marketing & launch intelligence
pstack-workspace/pstack/marketing-intel.md

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Dependency artifacts
node_modules/
__pycache__/
*.pyc

# Local env
.env
.env.local
