.claude/settings.json

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Dependency artifacts
node_modules/
__pycache__/
*.pyc

# Local env
.env
.env.local
